// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  name          String
  avatar        String?
  role          String // 'investor' | 'fund_manager' | 'admin'
  walletAddress String?
  createdAt     DateTime @default(now())
}

model Deal {
  id                   String   @id @default(uuid())
  name                 String
  entityName           String
  status               String // 'draft' | 'submitted' | 'onboarding' | 'closing' | 'close_requested' | 'closed' | 'test' | 'migration'
  type                 String // 'spv' | 'fund'
  productType          String // 'standard_spv' | 'premium_spv' | 'fund'
  managementFee        Float
  carry                Float
  targetRaise          Float
  minimumInvestment    Float
  totalSigned          Float
  totalWired           Float
  investorCount        Int
  estimatedClosingDate DateTime
  offeringType         String // '506b' | '506c' | 'reg_d' | 'reg_s'
  memo                 String?
  pitchDeckUrl         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  fundManagerId        String
  assetId              String?

  investments   Investment[]
  ledgerEntries LedgerEntry[]
  fees          Fee[]
}

model Investment {
  id                 String    @id @default(uuid())
  dealId             String
  dealName           String
  investorId         String
  investorName       String
  investorEmail      String
  investorType       String // 'individual' | 'entity'
  status             String // 'invited' | 'viewed' | 'completed' | 'signed' | 'committed'
  kycStatus          String // 'not_run' | 'pending' | 'approved' | 'needs_review' | 'rejected'
  subscriptionAmount Float
  capitalWired       Float
  managementFee      Float
  carry              Float
  createdAt          DateTime  @default(now())
  signedAt           DateTime?

  deal Deal @relation(fields: [dealId], references: [id])
}

model Asset {
  id           String   @id @default(uuid())
  legalName    String
  type         String // 'startup' | 'spv_into_fund' | 'secondary' | 'real_estate'
  industry     String?
  location     String
  securityType String // 'preferred_stock' | 'common_stock' | 'convertible_note' | 'safe' | 'secondary'
  totalShares  Float?
  sharePrice   Float?
  filesCount   Int
  createdAt    DateTime @default(now())
}

model Entity {
  id               String    @id @default(uuid())
  name             String
  type             String // 'llc' | 'lp'
  structure        String // 'independent' | 'series'
  masterEntityId   String? // Only for series entities
  masterEntityName String?
  state            String
  ein              String?
  address          String
  registeredAgent  String?
  formationDate    DateTime?
  createdAt        DateTime  @default(now())
}

model Identity {
  id                  String   @id @default(uuid())
  name                String
  type                String // 'individual' | 'entity'
  email               String
  phone               String?
  accreditationStatus String // 'pending' | 'verified' | 'expired' | 'not_verified'
  kycStatus           String // 'not_run' | 'pending' | 'approved' | 'needs_review' | 'rejected'
  createdAt           DateTime @default(now())
}

model LedgerEntry {
  id          String   @id @default(uuid())
  dealId      String
  dealName    String
  type        String // 'capital_call' | 'distribution' | 'management_fee' | 'carried_interest' | 'expense' | 'adjustment'
  description String
  amount      Float
  status      String // 'pending' | 'completed' | 'failed'
  date        DateTime
  createdAt   DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id])
}

model Fee {
  id          String    @id @default(uuid())
  dealId      String
  dealName    String
  type        String // 'management_fee' | 'performance_fee' | 'formation_fee' | 'administrative_fee' | 'other'
  description String
  amount      Float
  status      String // 'pending' | 'paid' | 'waived' | 'overdue'
  dueDate     DateTime
  paidDate    DateTime?
  createdAt   DateTime  @default(now())

  deal Deal @relation(fields: [dealId], references: [id])
}

model NewsArticle {
  id               String   @id @default(uuid())
  title            String
  summary          String
  content          String
  source           String
  sourceIcon       String?
  imageUrl         String?
  publishedAt      DateTime
  category         String
  relatedCompanies String[]
  featured         Boolean  @default(false)
}

model FileItem {
  id         String   @id @default(uuid())
  name       String
  type       String
  size       Int
  url        String
  uploadedAt DateTime
  uploadedBy String
}

model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  actionUrl String?
}
